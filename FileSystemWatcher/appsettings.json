{
  "Watcher": {
    "WatchedPaths": [
      "/tmp/dlpwatch"
    ],
    "IncludeSubdirectories": true,
    "EnableCopyHeuristic": true,
    "BatchFlushIntervalSeconds": 2,
    "BatchSize": 50,
    "CopyHeuristicMaxFiles": 1000,
    "IncludeExtensions": [],
    "ExcludeExtensions": [".tmp", ".log"],
    "IgnorePatterns": ["~$*", "*.tmp"],
    "BusinessHours": {
      "Start": "09:00",
      "End": "18:00"
    }
  },
  "StatusApi": {
    "Port": 5001
  }
}
